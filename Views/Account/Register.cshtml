@model GameWiki.DTOs.Auth.RegisterDto
@{
    ViewData["Title"] = "Rejestracja";
}

<div class="gw-auth-wrapper">
    <div class="gw-auth-card">
        <div class="gw-auth-header">
            <div class="gw-auth-icon">🎮</div>
            <h1 class="gw-auth-title">Utwórz konto</h1>
            <p class="gw-auth-sub">Dołącz do społeczności GameWiki</p>
        </div>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="gw-alert-error"></div>

            <div class="gw-form-group">
                <label asp-for="Username" class="gw-label"></label>
                <input asp-for="Username" class="gw-input" placeholder="Twoja nazwa użytkownika" />
                <span asp-validation-for="Username" class="gw-field-error"></span>
            </div>

            <div class="gw-form-group">
                <label asp-for="Email" class="gw-label"></label>
                <input asp-for="Email" class="gw-input" placeholder="twoj@email.com" />
                <span asp-validation-for="Email" class="gw-field-error"></span>
            </div>

            <div class="gw-form-group">
                <label asp-for="Password" class="gw-label"></label>
                <input asp-for="Password" class="gw-input" placeholder="Minimum 6 znaków" />
                <span asp-validation-for="Password" class="gw-field-error"></span>
            </div>

            <div class="gw-form-group">
                <label asp-for="ConfirmPassword" class="gw-label"></label>
                <input asp-for="ConfirmPassword" class="gw-input" placeholder="Powtórz hasło" />
                <span asp-validation-for="ConfirmPassword" class="gw-field-error"></span>
            </div>

            <button type="submit" class="gw-btn-primary gw-btn-full">
                Zarejestruj się
            </button>
        </form>

        <div class="gw-auth-footer">
            Masz już konto?
            <a asp-controller="Account" asp-action="Login" class="gw-auth-link">Zaloguj się</a>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}