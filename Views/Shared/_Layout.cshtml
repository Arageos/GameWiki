<!DOCTYPE html>
<html lang="pl" style="height: 100%;">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GameWiki</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GameWiki.styles.css" asp-append-version="true" />
</head>
<body id="top" style="min-height: 100vh; display: flex; flex-direction: column; margin: 0; background-color: #0f1117; color: #e2e8f0;">

    <nav class="navbar navbar-expand-sm navbar-toggleable-sm sticky-top" style="flex-shrink: 0; background: rgba(15, 17, 23, 0.85); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,255,255,0.05); z-index: 1030;">
        <div class="container">
            <a class="navbar-brand fw-bold text-white" asp-controller="Home" asp-action="Index">GameWiki</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item">
                        <a class="nav-link text-light" asp-controller="Games" asp-action="Index">Gry</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-light" asp-controller="Article" asp-action="Index">Artykuły</a>
                    </li>
                </ul>
                <ul class="navbar-nav align-items-center">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item dropdown gw-user-dropdown" style="z-index: 1050;">
                            <button class="btn dropdown-toggle gw-profile-btn" type="button" id="profileDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                                @{
                                    // Po prostu wyciągamy ścieżkę z Claimów
                                    var avatarUrl = User.FindFirst("AvatarUrl")?.Value;
                                }

                                @if (!string.IsNullOrEmpty(avatarUrl))
                                {
                                    <img src="@avatarUrl" alt="Avatar" class="rounded-circle" style="width: 32px; height: 32px; object-fit: cover; border: 2px solid #6366f1;" />
                                }
                                else
                                {
                                    <div class="gw-avatar-circle">
                                        @User.Identity.Name.Substring(0, 1).ToUpper()
                                    </div>
                                }
                                <span class="ms-2 d-none d-md-inline text-light">@User.Identity.Name</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end gw-dropdown-dark shadow-lg" aria-labelledby="profileDropdown">
                                <li class="dropdown-header">
                                    <div class="fw-bold text-white mb-2">@User.Identity.Name</div>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <span class="nav-badge-admin">ADMIN</span>
                                    }
                                    else if (User.IsInRole("Moderator"))
                                    {
                                        <span class="nav-badge-mod">MOD</span>
                                    }
                                </li>
                                <li><hr class="dropdown-divider border-secondary"></li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Profile">👤 Mój Profil</a>
                                    <a class="dropdown-item" asp-controller="Account" asp-action="Settings">⚙️ Ustawienia</a>
                                </li>
                                @if (User.IsInRole("Admin") || User.IsInRole("Moderator"))
                                {
                                    <li><hr class="dropdown-divider border-secondary"></li>
                                    <li class="nav-item">
                                        <a class="dropdown-item text-warning" asp-controller="Report" asp-action="Index">📊 Raporty</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item text-warning" asp-controller="Admin" asp-action="Index">🛡️ Panel Zarządzania</a>
                                    </li>
                                    <li class="nav-item">
                                        <a class="dropdown-item text-info"  asp-controller="GamesImport" asp-action="Index" class="nav-link">📥 Import RAWG</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item text-danger" asp-controller="Admin" asp-action="Reports">🚩 Zgłoszenia</a>
                                    </li>
                                    <li><hr class="dropdown-divider border-secondary"></li>
                                }
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0 p-0">
                                        <button type="submit" class="dropdown-item text-danger">🚪 Wyloguj się</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Account" asp-action="Login">Zaloguj się</a>
                        </li>
                        <li class="nav-item ms-2">
                            <a class="btn btn-primary rounded-pill px-3 py-1" asp-controller="Account" asp-action="Register">Rejestracja</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container" style="flex: 1 0 auto; padding-bottom: 2rem;">
        <main role="main">
            @RenderBody()
        </main>
    </div>
    <a href="#top" id="gw-back-to-top" title="Wróć na górę">↑</a>
    <footer style="flex-shrink: 0; background: rgba(15, 17, 23, 0.95); border-top: 1px solid rgba(255,255,255,0.07); color: #475569; padding: 1.5rem 0;">
        <div class="container">
            &copy; 2026 - GameWiki
        </div>
        <div class="modal fade" id="reportModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content bg-dark text-light border-secondary">
                    <div class="modal-header border-secondary">
                        <h5 class="modal-title text-warning">🚩 Zgłoś naruszenie</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form asp-controller="Reports" asp-action="Create" method="post">
                        <div class="modal-body">
                            <input type="hidden" name="type" id="reportType" value="" />
                            <input type="hidden" name="targetId" id="reportTargetId" value="" />
                            <input type="hidden" name="returnUrl" id="reportReturnUrl" value="" />

                            <p class="small text-muted mb-3">Opisz krótko, dlaczego zgłaszasz ten materiał. Administracja rozpatrzy to najszybciej, jak to możliwe.</p>

                            <div class="mb-3">
                                <label class="form-label text-uppercase small fw-bold" style="color: #94a3b8;">Powód zgłoszenia:</label>
                                <textarea name="reason" class="form-control bg-dark text-light border-secondary" rows="4" required maxlength="500"></textarea>
                            </div>
                        </div>
                        <div class="modal-footer border-secondary">
                            <button type="button" class="btn btn-outline-light rounded-pill" data-bs-dismiss="modal">Anuluj</button>
                            <button type="submit" class="btn btn-warning rounded-pill">Wyślij zgłoszenie</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <script>
            document.addEventListener('DOMContentLoaded', function () {
                var reportModal = document.getElementById('reportModal');
                if (reportModal) {
                    reportModal.addEventListener('show.bs.modal', function (event) {
                        var button = event.relatedTarget;
                        var type = button.getAttribute('data-report-type');
                        var targetId = button.getAttribute('data-report-targetid');
                        var returnUrl = window.location.pathname + window.location.search;

                        reportModal.querySelector('#reportType').value = type;
                        reportModal.querySelector('#reportTargetId').value = targetId;
                        reportModal.querySelector('#reportReturnUrl').value = returnUrl;
                    });
                }
            });
        </script>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>